{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/who.schema.json",
  "title": "GoPOSIX who --json output",
  "description": "Validates the complete JSON output of goposix who --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "who" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["users"], "properties": {"users": {"type": "array", "items": {"type": "object", "required": ["name", "terminal"], "properties": {"name": {"type": "string"}, "terminal": {"type": "string"}, "time": {"type": "string"}, "host": {"type": "string"}}}}, "count": {"type": "integer"}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
