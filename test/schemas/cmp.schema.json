{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/cmp.schema.json",
  "title": "GoPOSIX cmp --json output",
  "description": "Validates the complete JSON output of goposix cmp --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "cmp" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["equal"], "properties": {"equal": {"type": "boolean"}, "byte_pos": {"type": "integer"}, "line_num": {"type": "integer"}, "val1": {"type": "integer"}, "val2": {"type": "integer"}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
