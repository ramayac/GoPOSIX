{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/nl.schema.json",
  "title": "GoPOSIX nl --json output",
  "description": "Validates the complete JSON output of goposix nl --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "nl" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["lines"], "properties": {"lines": {"type": "array", "items": {"type": "object", "required": ["text"], "properties": {"number": {"type": "integer"}, "text": {"type": "string"}}}}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
