{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/patch.schema.json",
  "title": "GoPOSIX patch --json output",
  "description": "Validates the complete JSON output of goposix patch --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "patch" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["file", "applied", "rejected"], "properties": {"file": {"type": "string"}, "applied": {"type": "integer"}, "rejected": {"type": "integer"}, "is_new": {"type": "boolean"}, "message": {"type": "string"}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
