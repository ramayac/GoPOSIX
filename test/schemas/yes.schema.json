{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/yes.schema.json",
  "title": "GoPOSIX yes --json output",
  "description": "Validates the complete JSON output of goposix yes --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "yes" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["string", "count", "truncated"], "properties": {"string": {"type": "string"}, "count": {"type": "integer"}, "truncated": {"type": "boolean"}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
