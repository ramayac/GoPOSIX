{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goposix.dev/schemas/true.schema.json",
  "title": "GoPOSIX true --json output",
  "description": "Validates the complete JSON output of goposix true --json.",
  "type": "object",
  "required": ["command", "version", "schemaVersion", "exitCode", "data", "error"],
  "properties": {
    "command": { "type": "string", "const": "true" },
    "version": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "exitCode": { "type": "integer" },
    "data": {"type": "object", "required": ["exitCode", "value"], "properties": {"exitCode": {"type": "integer"}, "value": {"type": "boolean"}}},
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}
